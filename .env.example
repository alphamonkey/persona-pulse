# Bluesky (atproto) — create an account, then an App Password in Settings
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Claude — used only to write post copy from detected data (cheap model, low volume)
ANTHROPIC_API_KEY=sk-ant-...

# Mode — start in dry-run (detect + write, but DO NOT publish)
PULSE_MODE=dryrun          # dryrun | live
